	VitalTileSettings: {
		DisplayName: 重要方块设置

		Headers: {
			Spread: 传播速度
			Buffs: Buff强度
			Seeds: 种子掉落几率
			Debug: 调试
		}

		VitalSoilSpreadChance: {
			Label: 生命土壤传播几率
			Tooltip: 生命土壤方块每次随机更新时将一个相邻的泥土、泥浆或淤泥方块转化的几率。设为0则禁用传播。
		}

		VitalQuartzSpreadChance: {
			Label: 生命石英传播几率
			Tooltip: 生命石英方块每次随机更新时将一个相邻的石块转化的几率。设为0则禁用传播。
		}

		VitalSoilRegenPercent: {
			Label: 生命土壤回复提升(%)
			Tooltip: 玩家站在生命土壤上时，以当前生命回复的百分比形式回复生命。
		}

		VitalQuartzMaxHpPercent: {
			Label: 生命石英最大生命提升(%)
			Tooltip: 玩家处于生命石英方块范围内时，以最大生命的百分比形式增加生命值。
		}

		VitalQuartzVerticalRange: {
			Label: 生命石英垂直范围（格）
			Tooltip: 生命石英方块光环向上或向下延伸的距离。
		}

		VitalQuartzHorizontalRange: {
			Label: 生命石英水平范围（格）
			Tooltip: 生命石英方块光环向两侧延伸的距离。比垂直范围小，以鼓励采用列式种植。
		}

		LifeCrystalSeedChance: {
			Label: 生命水晶种子几率(%)
			Tooltip: 提炼的生命水晶同时产出生命水晶种子的几率。该几率与标准碎片产出独立计算。
		}

		LifeFruitSeedChance: {
			Label: 生命果实种子几率(%)
			Tooltip: 提炼的生命果实产出生命果实种子的几率。提炼生命果实只会产出种子——如果未触发则消耗果实而不获得任何东西。
		}

		DebugFastSeedPlantGrowth: {
			Label: 快速种子植物生长
			Tooltip: 调试选项。启用时，生命水晶和生命果实种子植物会在每次随机方块更新时生长。
		}

		Tooltip: ""
	}

	UISettings: {
		DisplayName: 界面设置

		Headers: {
			UI: 心形物品清单 & HUD
			Abilities: 能力
		}

		EnableHeartChecklist: {
			Label: 启用心形物品清单
			Tooltip: 显示心形物品清单按钮和面板，用于追踪你可以找到或制作的每一个心形物品。
		}

		ShowDetailedHeartStats: {
			Label: 显示详细统计栏
			Tooltip: 在心形物品清单底部显示详细的统计栏（总计和各等级数量）。
		}

		EnableElementalHP: {
			Label: 启用元素生命条
			Tooltip:
				'''
				将你的生命条心形物品重新着色，以匹配你已消耗的最高等级。
				关闭以保留原版红色心形物品。
				'''
		}

		ShowPermanentBuffs: {
			Label: 显示永久Buff图标
			Tooltip: 显示由已消耗的药水之心提供的永久效果的Buff图标。
		}

		HideImpossibleHearts: {
			Label: 隐藏无法获得的心形物品
			Tooltip:
				'''
				将你当前无法获得的心形物品（它们的来源模组被禁用或不存在）
				从心形物品清单中隐藏，而不是将它们变灰。
				'''
		}

		AdvancedNavigation: {
			Label: 高级导航
			Tooltip:
				'''
				在心形物品日志的心形物品标签中显示搜索栏、排序和筛选控件。
				默认关闭以保持面板整洁。
				'''
		}

		BulkOptionButtons: {
			Label: 批量选项按钮
			Tooltip:
				'''
				在心形物品日志的激活和协同标签中显示全部激活和全部禁用按钮。
				默认关闭以保持工具栏整洁。
				'''
		}

		DraggableUI: {
			Label: 可拖动生命碎片界面
			Tooltip:
				'''
				启用后，生命碎片面板可以被点击并拖动到任意屏幕位置。
				新位置会自动保存到下方的界面位置中。
				'''
		}

		UIPosition: {
			Label: 生命碎片界面位置
			Tooltip:
				'''
				生命碎片面板的保存屏幕坐标。仅在启用可拖动界面时使用。
				将两者都设置为0以回退到默认位置。
				'''
		}

		Tooltip: ""
	}

	CameraSettings: {
		DisplayName: 相机设置

		Headers: {
			General: 通用
			Strength: 平移强度
			Feel: 感觉
			Behaviour: 行为
		}

		EnableCursorFocus: {
			Label: 启用光标聚焦
			Tooltip:
				'''
				放大之心相机平移的全局开关。关闭时，无论每个角色的心形物品清单开关如何设置，
				相机都不会跟随光标。
				'''
		}

		MaxPanDistance: {
			Label: 最大平移距离（像素）
			Tooltip: 当光标被推到屏幕边缘时，相机移动的距离（以像素为单位）。
		}

		HorizontalStrength: {
			Label: 水平强度(%)
			Tooltip: 水平平移的乘数。100为完整强度；0禁用水平平移。
		}

		VerticalStrength: {
			Label: 垂直强度(%)
			Tooltip: 垂直平移的乘数。100为完整强度；0禁用垂直平移。
		}

		Smoothing: {
			Label: 平滑
			Tooltip: 跟随感觉的流畅程度。0立即对齐光标；100缓慢漂移对齐。
		}

		Deadzone: {
			Label: 死区(%)
			Tooltip: 光标可以在其中停留而相机不会反应的中心区域，以半屏的百分比表示。
		}

		ResponseCurve: {
			Label: 响应曲线
			Tooltip:
				'''
				平移的缓动效果。1为线性；更高的值会让相机在中心附近更平静，
				仅在光标靠近边缘时才会增强。
				'''
		}

		OnlyWhileUsingItem: {
			Label: 仅使用物品时
			Tooltip: 启用时，相机仅在你主动挥动或瞄准物品时才会平移。
		}

		RecenterInMenus: {
			Label: 菜单中重置中心
			Tooltip: 启用时，打开背包或任何模组菜单会将相机滑回中心。
		}

		InvertHorizontal: {
			Label: 反转水平
			Tooltip: 翻转水平平移方向。
		}

		InvertVertical: {
			Label: 反转垂直
			Tooltip: 翻转垂直平移方向。
		}

		Tooltip: ""
	}

	IdleSettings: {
		DisplayName: 闲置游戏设置
		Headers.IdleGameSettings: 闲置碎片生成

		EnableIdleGame: {
			Label: 启用闲置游戏
			Tooltip: 启用时，已解锁并已消耗的心形物品会随着时间缓慢生成生命碎片供你领取。
		}

		BaseCapacity: {
			Label: 基础碎片容量
			Tooltip: 在生成暂停前你可以储存的未领取碎片的基础最大数量。
		}

		CapacityPerTier: {
			Label: 每世界等级容量
			Tooltip: 你已达到的每个世界等级提供的额外未领取碎片容量。
		}

		Tooltip: ""
	}

	CapacitySettings: {
		DisplayName: 容量设置
		Headers.ProgressionGates: 生命值容量关卡

		EnableProgressionGates: {
			Label: 启用容量关卡
			Tooltip:
				'''
				启用时，你可以从心形物品中储存的总最大生命值加成会在每个Boss进度阶段
				设有上限，所以你的生命值不会超过世界等级。
				关闭以自由消耗心形物品。
				'''
		}

		PreBossCapacity: {
			Label: 上限——击败Boss前
			Tooltip: 在击败任何Boss前允许的最大心形物品生命值加成。
		}

		PostSkeletronCapacity: {
			Label: 上限——击败骷髅王后
			Tooltip: 击败骷髅王后允许的最大心形物品生命值加成。
		}

		PostWoFCapacity: {
			Label: 上限——击败血肉之墙后
			Tooltip: 击败血肉之墙（进入困难模式）后允许的最大心形物品生命值加成。
		}

		Post1MechCapacity: {
			Label: 上限——击败1个机械Boss后
			Tooltip: 击败一个机械Boss后允许的最大心形物品生命值加成。
		}

		Post2MechsCapacity: {
			Label: 上限——击败2个机械Boss后
			Tooltip: 击败两个机械Boss后允许的最大心形物品生命值加成。
		}

		Post3MechsCapacity: {
			Label: 上限——击败3个机械Boss后
			Tooltip: 击败所有三个机械Boss后允许的最大心形物品生命值加成。
		}

		PostPlanteraCapacity: {
			Label: 上限——击败世纪之花后
			Tooltip: 击败世纪之花后允许的最大心形物品生命值加成。
		}

		PostGolemCapacity: {
			Label: 上限——击败石巨人后
			Tooltip: 击败石巨人后允许的最大心形物品生命值加成。
		}

		PostCultistCapacity: {
			Label: 上限——击败邪教徒后
			Tooltip: 击败邪教徒后允许的最大心形物品生命值加成。
		}

		PostMoonLordCapacity: {
			Label: 上限——击败月亮领主后
			Tooltip: 击败月亮领主后允许的最大心形物品生命值加成。
		}

		UnlimitedPostMoonLord: {
			Label: 月亮领主后无上限
			Tooltip: 启用时，一旦击败月亮领主，容量关卡将完全移除。
		}

