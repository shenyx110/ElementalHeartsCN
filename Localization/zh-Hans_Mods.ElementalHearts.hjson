			World: 世界
			LifeShards: 生命碎片
			VitalTiles: 生命方块
		}

		OrdealsOfTheHearts: {
			Label: 心形试炼
			Tooltip:
				'''
				单一的硬核挑战模式。开启后会将整个试炼套装叠加到你当前的设置上：
				心脏病发作、损耗（死亡时掉落心形物品）、心形物品提供双倍生命值和容量限制、
				双倍碎片生成和消耗、双倍商店和协同效果价格、心形物品配方征税、药水治疗减半但碎片治疗翻倍、
				更稀有的心形流星、Boss心形物品不再必掉、1点生命值开始、生命水晶仅提供5点生命值。
				在开始世界之前设置——需要重载才能生效。默认禁用。
				'''
		}

		BossDrops: {
			Label: Boss掉落设置
			Tooltip: ""
