	HPSettings: {
		DisplayName: 生命值设置

		Headers: {
			Difficulty: 难度
			Challenge: 挑战模式
			CraftableTiers: 可制作的等级心形物品
			BossTiers: Boss等级心形物品
		}

		DifficultyBalancing: {
			Label: 难度平衡
			Tooltip:
				'''
				你会受到来自所有来源的额外伤害，根据当前世界允许的元素生命值进行缩放：
				早期大约+3%，到终局时增加到+20%。这使心形物品提供的更大生命值条真正有用。默认启用。
				'''
		}

		ChallengeMode: {
			Label: 挑战模式
			Tooltip:
				'''
				硬核生命值规则。你的最大生命从1开始，生命水晶只给5点（从20降低），
				因此心形物品成为你增加生命值条的真正途径。作为补偿，每个心形物品给予其配置生命值的两倍。
				默认禁用。
				'''
		}

		Common: {
			Label: 普通级心形物品生命值
			Tooltip: 每个普通级心形物品在消耗时给予的最大生命。默认值2。
		}

		Uncommon: {
			Label: 稀有级心形物品生命值
			Tooltip: 每个稀有级心形物品在消耗时给予的最大生命。默认值4。
		}

		Rare: {
			Label: 精良级心形物品生命值
			Tooltip: 每个精良级心形物品在消耗时给予的最大生命。默认值6。
		}

		Epic: {
			Label: 史诗级心形物品生命值
			Tooltip: 每个史诗级心形物品在消耗时给予的最大生命。默认值8。
		}

		Legendary: {
			Label: 传说级心形物品生命值
			Tooltip: 每个传说级心形物品在消耗时给予的最大生命。默认值10。
		}

		Exotic: {
			Label: 异国级心形物品生命值
			Tooltip: 每个异国级（原版Boss）心形物品在消耗时给予的最大生命。默认值10。
		}

		Mythic: {
			Label: 神话级心形物品生命值
			Tooltip: 每个神话级（活化者最终Boss）心形物品在消耗时给予的最大生命。默认值50。
		}

		Tooltip: ""
	}

	RecipeSettings: {
		DisplayName: 配方设置
		Headers.Crafting: 制作难度

		RecipeDifficulty: {
			Label: 配方难度 (x0.1 成本)
			Tooltip:
				'''
				缩放每个心形物品配方所需的材料。
				10是默认值(1x成本)；5是一半成本，20是两倍。
				需要重载。
				'''
		}

		Tooltip: ""
	}

	VisualSettings: {
		DisplayName: 视觉设置

		Headers: {
			Effects: 消耗效果
			UI: 抬头显示
			Performance: 性能
		}

		ConsumptionEffectStrength: {
			Label: 消耗效果强度
			Tooltip:
				'''
				缩放心形物品消耗效果的粒子、屏幕震动和光照。
				1为微妙，3为默认，5为强烈。
				'''
		}

		UsePerformanceShaders: {
			Label: 性能着色器
			Tooltip:
				'''
				用简化的低成本版本替换动画面板和Boss着色器。
				不推荐——只有在你使用旧电脑或集成显卡，
				并且在心形物品清单打开时或活化者Boss战期间遇到卡顿才启用。
				需要重载模组才能生效。
				'''
		}

		Tooltip: ""

		EnablePassiveHeartsEffect: {
			Label: 启用被动心形物品效果
			Tooltip: ""
		}
	}

	DebugSettings: {
		DisplayName: 调试设置

		ShowBombetteDebugOverlay: {
			Label: 显示 Bombette 调试覆盖层
			Tooltip: 在游戏中 Bombette 上方显示她的当前状态、选定计划、目标、路径、卡住计时器和爆炸计划。
		}

		Tooltip: ""
	}

	TipSettings: {
		DisplayName: 提示设置
		Headers.Tips: 游戏内提示

		EnableTips: {
			Label: 启用提示
			Tooltip: 启用后，生命碎片UI上会显示有用的游戏内提示（例如活化者进度提示）。关闭则隐藏所有提示徽章。
		}

		Tooltip: ""
	}

	WorldSettings: {
		DisplayName: 世界设置

		Headers: {
			Progression: 进度
			Cheats: 作弊
			ResetActions: 重置操作（一次性）
			Worldgen: 小型生物群系生成
			NightEvents: 夜间事件
		}

		ClearHeartRegistry: {
			Label: 清空已消耗心形物品记录
			Tooltip:
				'''
				启用以重置该世界已消耗心形物品记录并退还其提供的最大生命值，
				使每个心形物品可以再次被消耗。执行后会自动重置。
				'''
		}

		ClearElementalTier: {
			Label: 清空元素等级
			Tooltip:
				'''
				启用以将该世界的活化者进度等级重置回起始等级。
				执行后会自动重置。
				'''
		}

		SurfaceBiomeCountMultiplier: {
			Label: 地表生物群系数量倍数
			Tooltip:
				'''
				地表生命土壤生物群系数量的倍数。1为默认值（小世界约3个，
				中世界约5个，大世界约7个）。设为0则仅禁用地表生物群系。
				'''
		}

		JungleBiomeCountMultiplier: {
			Label: 丛林生物群系数量倍数
			Tooltip: 丛林生命石英生物群系数量的倍数。1为默认值（小世界约3个，中世界约4个，大世界约6个）。设为0则仅禁用丛林生物群系。
		}

		HeartShootingStarChance: {
			Label: 心形流星几率(%)
			Tooltip: 每个符合条件的夜晚，心形流星落下的百分比几率。
		}

		HeartShootingStarMaxPerNight: {
			Label: 每晚最大心形流星数
			Tooltip: 单个夜晚可以落下的最大心形流星数量。
		}

		HeartShootingStarFrequency: {
			Label: 心形流星频率
			Tooltip: 夜晚激活后流星尝试落下的频率。数值越高落下越频繁。
		}

		SharedProgression: {
			Label: 共享进度
			Tooltip:
				'''
				启用后，消耗一个心形物品会标记为全世界已使用——所有玩家从一个共享的收藏中获取，每个心形物品只能被消耗一次。
				关闭后，每个角色保持自己独立的进度。
				'''
		}

		AdminMode: {
			Label: 管理员模式
			Tooltip: 无论进度如何都在Heart Log中显示每一个心形物品，用于测试或观看。不改变实际可消耗的内容。
		}

		Tooltip: 设置心形流星掉落的相关参数。

		HeartShootingStarFalloffMultiplier: {
			Tooltip: 每击败一个敌人，心形流星掉落的额外几率就会减少该倍数。设置为1则每次击杀都会重置为满额几率。
			Label: 心形流星衰减倍数
		}
