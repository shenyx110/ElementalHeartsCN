	BossSettings: {
		DisplayName: Boss掉落设置
		Headers.Drops: Boss心形物品掉落

		BossHeartsGuaranteedOnFirstKill: {
			Label: 首次击杀必掉
			Tooltip:
				'''
				启用时，你第一次击败Boss时总会掉落其主题心形物品。
				下面的掉落几率仅适用于之后的击杀。
				'''
		}

		BossHeartDropChance: {
			Label: Boss心形物品掉落几率(%)
			Tooltip: Boss在首次击杀后的每次击杀中掉落其主题心形物品的百分比几率。
		}

		Tooltip: ""
	}

	ElementalHeartsCrossModConfig: {
		DisplayName: 跨模组设置
		Headers.SupportedMods: 支持的模组

		EnableCalamityHearts: {
			Label: 启用灾厄生命水晶
			Tooltip: 加载灾厄模组主题的生命水晶。禁用则完全移除。需要重载。
		}

		EnableThoriumHearts: {
			Label: 启用神谕生命水晶
			Tooltip: 加载神谕模组主题的生命水晶。禁用则完全移除。需要重载。
		}

		EnableConsolariaHearts: {
			Label: 启用Consolaria生命水晶
			Tooltip: 加载Consolaria内容主题的生命水晶。禁用则完全移除。需要重载。
		}

		EnableWrathOfTheGodsHearts: {
			Label: 启用诸神之怒生命水晶
			Tooltip:
				'''
				加载灾厄：诸神之怒内容主题的生命水晶。
				禁用则完全移除。无法制作、掉落或找到。
				需要重载。
				'''
		}

		EnableFargoSoulsHearts: {
			Label: 启用法戈之魂生命水晶
			Tooltip:
				'''
				加载法戈之魂模组内容主题的生命水晶。
				禁用则完全移除。无法制作、掉落或找到。
				需要重载。
				'''
		}
