# BossChecklist integration: spawn / despawn strings shown on each Animate
# boss's entry page. The [i:ItemInternalName] chat tag renders the spawn item's
# icon inline; "{0}" in despawn messages is replaced with the NPC's full name.
BossChecklist: {
	CommonAnimate: {
		SpawnInfo: 在任何地方使用 [i:ElementalHearts/CommonMenacingHeart]。使用 [i:LifeCrystal] 在恶魔祭坛处永远可以制作。
		DespawnMessage: "{0} 退入黑暗之中，等待时机。"
	}

	UncommonAnimate: {
		SpawnInfo: 在任何地方使用 [i:ElementalHearts/UncommonMenacingHeart]。只有在击败普通活化者后，才能使用 [i:LifeCrystal] 在恶魔祭坛处制作。
		DespawnMessage: "{0} 从这个世界上消失，其威胁无人应答。"
	}

	RareAnimate: {
		SpawnInfo: 在任何地方使用 [i:ElementalHearts/RareMenacingHeart]。只有在击败稀有活化者后，才能使用 [i:LifeCrystal] 在恶魔祭坛处制作。
		DespawnMessage: "{0} 从这个世界上消失，其威胁无人应答。"
	}

	EpicAnimate: {
		SpawnInfo: 在任何地方使用 [i:ElementalHearts/EpicMenacingHeart]。只有在击败精良活化者后，才能使用 [i:LifeCrystal] 在恶魔祭坛处制作。
		DespawnMessage: "{0} 从这个世界上消失，其威胁无人应答。"
	}

	LegendaryAnimate: {
		SpawnInfo: 在任何地方使用 [i:ElementalHearts/LegendaryMenacingHeart]。只有在击败史诗活化者后，才能使用 [i:LifeCrystal] 在恶魔祭坛处制作。
		DespawnMessage: "{0} 从这个世界上消失，其威胁无人应答。"
	}
}

